# GitHub Configuration
# Use EITHER token auth OR app auth (not both)

# Option 1: Token Auth (PAT - legacy mode)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: GitHub App Auth (recommended)
# Note: App ID and private key are embedded at build time
# You only need to configure the installation ID at runtime
GITHUB_APP_INSTALLATION_ID=12345678

# Target repository to watch
TARGET_REPO=owner/repo

# AI Backend Configuration
# Choose "claude" or "opencode" (default: opencode)
AI_BACKEND=opencode

# Claude Configuration (only needed if AI_BACKEND=claude)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=sonnet

# OpenCode Configuration (only needed if AI_BACKEND=opencode)
# Default: Kimi K2.5 free model (no API key required)
OPENCODE_MODEL=opencode/kimi-k2.5-free
# For other models, see: https://opencode.ai/docs/models/
#
# Custom Providers/Credentials (optional):
# 1. Run `opencode auth login` locally to configure providers
# 2. Copy ~/.config/opencode/ to ./opencode-config/
# 3. Copy ~/.local/share/opencode/auth.json to ./opencode-auth.json
# 4. Uncomment volume mounts in docker-compose.yml

# Polling Configuration
POLL_INTERVAL=60

# Database Configuration
RESET_DB=false

# Debug Configuration
DEBUG=false
